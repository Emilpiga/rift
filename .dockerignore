# dockerignore for rift-server image. Trims the build context to
# just the bits we actually compile — keeps `docker build` fast
# and prevents leaking dev artefacts (target/, .git, IDE state).

target/
**/target/
.git
.github
.vscode
.idea
*.md
docs/

# Massive art assets aren't needed for a headless server build.
assets/icons
assets/models
assets/textures
assets/audio
assets/shaders/*.spv

# Local docker volume / dumps
docker-compose.yml
*.log

# Playtest-client packaging output and cargo-about config —
# only consumed by `scripts/package-client.*` and
# `scripts/gen-third-party.*` on the build host, never by the
# server image. Keeps the build context tight.
dist/
about.toml
about.hbs
