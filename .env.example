# Copy to .env for local/private settings. .env is gitignored.

# Server baked into packaged playtest clients.
RIFT_DEFAULT_SERVER=YOUR_SERVER:34000

# Public download URL for the launcher manifest and files.
RIFT_LAUNCHER_BASE_URL=https://pub-275f646594684e8e95e129240c1882ca.r2.dev/playtest

# Upload destination for scripts/rift.ps1 -Release -Launcher.
# Local folders are copied directly; non-local values use rclone copy.
RIFT_LAUNCHER_UPLOAD=rift-r2:rift/playtest